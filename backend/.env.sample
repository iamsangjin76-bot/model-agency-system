# ============================================
# Model Agency Management System - Environment Variables
# ============================================
# 이 파일을 .env 로 복사하고 실제 값으로 채우세요

# ---------- 앱 설정 ----------
APP_NAME=Model Agency Management System
APP_VERSION=1.0.0
DEBUG=true

# ---------- 서버 ----------
HOST=0.0.0.0
PORT=8000

# ---------- 데이터베이스 ----------
DATABASE_URL=sqlite:///./model_agency.db

# ---------- JWT 보안 ----------
SECRET_KEY=your-secret-key-change-in-production-model-agency-2025
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# ---------- 외부 API 키 ----------
# 이미지 검색 API (필요한 서비스의 키를 입력하세요)
UNSPLASH_ACCESS_KEY=your_unsplash_access_key
BING_SEARCH_API_KEY=your_bing_search_api_key
AZURE_COMPUTER_VISION_KEY=your_azure_cv_key

# 뉴스 검색 API
NEWS_API_KEY=your_news_api_key
# 또는 Google News용 (RSS 등)

# 문서 생성 API
OPENAI_API_KEY=your_openai_api_key

# ---------- 파일 저장 경로 ----------
UPLOAD_DIR=./uploads
MODEL_FILES_DIR=./model_files

# ---------- 선택: 캐시/레디스 (향후 확장) ----------
# REDIS_URL=redis://localhost:6379/0
