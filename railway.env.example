# Railway 환경변수 설정 예시
# Railway 대시보드 > Variables 탭에 아래 값들을 입력하세요
# 실제 값은 Railway 대시보드에서만 입력 (이 파일에는 절대 입력 금지)

# 필수
SECRET_KEY=랜덤_문자열_여기_입력
DATABASE_URL=sqlite:////data/model_agency.db
UPLOAD_DIR=/data/uploads
MODEL_FILES_DIR=/data/model_files
IMAGE_PROXY_CACHE_DIR=/data/proxy_cache

# 네이버 API (뉴스/이미지 검색)
NAVER_CLIENT_ID=여기에_입력
NAVER_CLIENT_SECRET=여기에_입력

# 인스타그램 (나중에 토큰 발급 후 입력)
# INSTAGRAM_ACCESS_TOKEN=여기에_입력
# INSTAGRAM_MY_IG_USER_ID=여기에_입력
